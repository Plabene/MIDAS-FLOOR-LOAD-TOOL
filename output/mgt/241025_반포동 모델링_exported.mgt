   RS, RX, RY, NO, None

*SCALEUP-RS    ; Scale Up for Response Spectrum Load Cases
; LCNAME, FACTOR  ; from line 1
RX, 1.62
RY, 1.69

*WINDDIRCT-LC    ; Load cases for Wind Direction
; TYPE, WIND_DIRECT ; from line 1
; AUTO, BUILDINGTYPE, LC_ALONG, LC_ACROSS, LC_TORSION, FACTOR_GD, FACTOR_K, ...  ; from line 2
